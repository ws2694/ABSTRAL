# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Authentication (set to enable password protection)
# ABSTRAL_AUTH_TOKEN=your-shared-password-here

# Optional: Multi-provider support
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Optional: Data directory (default: data/)
# DATA_DIR=/data

# Optional: CORS origins (default: * for local dev)
# CORS_ORIGINS=https://abstral.fly.dev
